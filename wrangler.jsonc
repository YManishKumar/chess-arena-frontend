{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chess-arena-frontend",
  "compatibility_date": "2026-04-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist/chess-arena-frontend/browser",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
